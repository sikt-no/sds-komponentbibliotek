{
  "name": "@sikt/horisont",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Sikt Design System",
  "homepage": "",
  "bugs": {
    "url": "https://gitlab.sikt.no/designsystem/horisont/-/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.sikt.no/designsystem/horisont.git"
  },
  "workspaces": [
    "packages/*",
    "storybook"
  ],
  "scripts": {
    "prebuild": "npm run clean",
    "build": "npm run build --workspaces --if-present",
    "clean": "rimraf packages/**/dist",
    "format": "prettier --write . --ignore-unknown",
    "lint": "run-p lint:*",
    "lint:css": "stylelint \"**/*.{css,pcss}\" --ignore-path .gitignore",
    "lint:ts": "eslint \"**/*.{ts,tsx}\" --ignore-path .gitignore",
    "prepare": "husky install",
    "prerelease": "cross-var npm run build --workspace=packages/$npm_config_package --if-present",
    "release": "standard-version",
    "storybook": "npm run storybook --workspace=storybook",
    "storybook:build": "npm run build-storybook --workspace=storybook",
    "test": "jest"
  },
  "browserslist": [
    ">0.2% in NO",
    "not dead",
    "not ie <= 11"
  ],
  "lint-staged": {
    "**/*.css": "stylelint --fix",
    "**/*.{ts,tsx}": "eslint --fix",
    "**/*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.3.0",
    "@commitlint/config-conventional": "^17.3.0",
    "@rollup/plugin-url": "^8.0.1",
    "@svgr/rollup": "^6.5.1",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/jest": "^29.2.5",
    "@types/jest-axe": "^3.5.5",
    "@types/react": "^18.0.26",
    "@types/react-dom": "^18.0.10",
    "@typescript-eslint/eslint-plugin": "^5.48.0",
    "@typescript-eslint/parser": "^5.48.0",
    "autoprefixer": "^10.4.13",
    "clsx": "^1.2.1",
    "copyfiles": "^2.4.1",
    "cross-var": "^1.1.0",
    "eslint": "^8.31.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-jsx-a11y": "^6.6.1",
    "eslint-plugin-react": "^7.31.11",
    "husky": "^8.0.3",
    "jest": "^29.3.1",
    "jest-axe": "^7.0.0",
    "jest-environment-jsdom": "^29.3.1",
    "jest-esm-transformer": "^1.0.0",
    "lint-staged": "^13.1.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.20",
    "postcss-custom-media": "^9.0.1",
    "postcss-import": "^15.1.0",
    "postcss-nested": "^6.0.0",
    "prettier": "2.8.1",
    "rimraf": "^3.0.2",
    "rollup": "^3.9.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-terser": "^7.0.2",
    "rollup-plugin-ts": "^3.0.2",
    "standard-version": "^9.5.0",
    "stylelint": "^14.16.1",
    "stylelint-config-prettier": "^9.0.4",
    "stylelint-config-standard": "^29.0.0",
    "ts-jest": "^29.0.3",
    "typescript": "^4.9.4"
  }
}
