{
  "name": "@sikt/sds-komponentbibliotek",
  "version": "1.0.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "description": "Sikt component library",
  "homepage": "https://designsystem.sikt.no/",
  "bugs": {
    "url": "https://gitlab.sikt.no/designsystem/sds-komponentbibliotek/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.sikt.no/designsystem/sds-komponentbibliotek.git"
  },
  "engines": {
    "node": "20.18.2"
  },
  "packageManager": "npm@11.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "prebuild": "npm run clean && npm run prebuild --workspaces --if-present",
    "clean": "run-p clean:*",
    "clean:build": "rimraf --glob packages/*/{build,dist}",
    "clean:gatsby": "npm run clean --workspace=apps/gatsby",
    "clean:storybook": "rimraf apps/storybook/storybook-static && rimraf apps/storybook/node_modules/.cache",
    "dev": "run-p gatsby storybook",
    "format": "prettier --write . --ignore-unknown",
    "gatsby": "npm run develop --workspace=apps/gatsby",
    "gatsby:build": "npm run build:prod --workspace=apps/gatsby",
    "init": "turbo gen init-package",
    "postinstall": "npm run prebuild --workspaces --if-present",
    "lint": "run-p lint:*",
    "lint:css": "stylelint \"**/*.{css,pcss}\" --ignore-path .gitignore",
    "lint:ts": "eslint \"**/*.{ts,tsx}\" --ignore-path .gitignore",
    "prepare": "husky",
    "release": "commit-and-tag-version",
    "prerelease": "cross-replace npm run build --workspace=packages/$npm_config_package --if-present",
    "storybook": "npm run dev --workspace=apps/storybook",
    "storybook:build": "npm run build:prod --workspace=apps/storybook",
    "test": "npm run test:unit",
    "test:unit": "jest",
    "test:e2e": "playwright test"
  },
  "browserslist": [
    "extends @sikt/browserslist-config-sds"
  ],
  "lint-staged": {
    "**/*.{css,pcss}": "stylelint --fix",
    "**/*.{ts,tsx}": "eslint --fix",
    "**/*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@figma/code-connect": "^1.2.4",
    "@playwright/test": "^1.50.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@turbo/gen": "^2.4.0",
    "@types/jest": "^29.5.14",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20.17.17",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "browserslist": "^4.24.4",
    "browserslist-to-esbuild": "^2.1.1",
    "clsx": "^2.1.1",
    "commit-and-tag-version": "^12.5.0",
    "cross-replace": "^0.2.0",
    "esbuild-plugin-svgr": "^3.1.0",
    "esbuild-postcss": "^0.0.4",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-axe": "^9.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-esm-transformer": "^1.0.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^15.4.3",
    "npm-run-all2": "^7.0.2",
    "postcss": "^8.5.1",
    "postcss-custom-media": "^11.0.5",
    "postcss-import": "^16.1.0",
    "postcss-nested": "^7.0.2",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "stylelint": "^16.14.1",
    "terser": "^5.37.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.6",
    "turbo": "^2.4.0",
    "typescript": "^5.7.3",
    "usehooks-ts": "^3.1.1"
  }
}
