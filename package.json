{
  "name": "@sikt/sds-komponentbibliotek",
  "version": "1.0.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "description": "Sikt component library",
  "homepage": "https://designsystem.sikt.no/komponenter/",
  "bugs": {
    "url": "https://gitlab.sikt.no/designsystem/sds-komponentbibliotek/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.sikt.no/designsystem/sds-komponentbibliotek.git"
  },
  "workspaces": [
    "packages/*",
    "gatsby",
    "storybook"
  ],
  "scripts": {
    "prebuild": "npm run clean && npm run prebuild --workspaces --if-present",
    "build": "turbo run build",
    "clean": "run-p clean:*",
    "clean:build": "rimraf packages/**/{build,dist}",
    "clean:gatsby": "rimraf gatsby/public",
    "clean:storybook": "rimraf storybook/storybook-static",
    "format": "prettier --write . --ignore-unknown",
    "init": "bin/init-package.sh $npm_config_package",
    "lint": "run-p lint:*",
    "lint:css": "stylelint \"**/*.{css,pcss}\" --ignore-path .gitignore",
    "lint:ts": "eslint \"**/*.{ts,tsx}\" --ignore-path .gitignore",
    "prepare": "husky install",
    "prerelease": "cross-var npm run build --workspace=packages/$npm_config_package --if-present",
    "release": "standard-version",
    "storybook": "npm run dev --workspace=storybook",
    "storybook:build": "npm run build:prod --workspace=storybook",
    "gatsby": "npm run develop --workspace=gatsby",
    "gatsby:build": "npm run build:prod --workspace=gatsby",
    "test": "jest"
  },
  "browserslist": [
    ">0.2% in NO",
    "not dead",
    "not ie <= 11"
  ],
  "lint-staged": {
    "**/*.{css,pcss}": "stylelint --fix",
    "**/*.{ts,tsx}": "eslint --fix",
    "**/*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.7.1",
    "@commitlint/config-conventional": "^17.7.0",
    "@rollup/plugin-commonjs": "^25.0.4",
    "@rollup/plugin-node-resolve": "^15.2.0",
    "@rollup/plugin-terser": "^0.4.3",
    "@rollup/plugin-url": "^8.0.1",
    "@svgr/rollup": "^8.1.0",
    "@testing-library/jest-dom": "^6.1.3",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/jest": "^29.5.4",
    "@types/jest-axe": "^3.5.5",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.6.0",
    "@typescript-eslint/parser": "^6.6.0",
    "autoprefixer": "^10.4.15",
    "clsx": "^2.0.0",
    "cross-var": "^1.1.0",
    "eslint": "^8.49.0",
    "husky": "^8.0.3",
    "jest": "^29.6.4",
    "jest-axe": "^8.0.0",
    "jest-environment-jsdom": "^29.6.4",
    "jest-esm-transformer": "^1.0.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^14.0.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.28",
    "postcss-custom-media": "^10.0.0",
    "postcss-import": "^15.1.0",
    "postcss-nested": "^6.0.1",
    "prettier": "^2.8.8",
    "rimraf": "^5.0.1",
    "rollup": "^3.28.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-ts": "^3.2.0",
    "standard-version": "^9.5.0",
    "stylelint": "^15.10.3",
    "ts-jest": "^29.1.1",
    "turbo": "^1.10.13",
    "typescript": "^5.2.2"
  }
}
