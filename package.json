{
  "name": "@sikt/sds-komponentbibliotek",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "description": "Sikt component library",
  "homepage": "https://komponentbibliotek.paas2.uninett.no/",
  "bugs": {
    "url": "https://gitlab.sikt.no/designsystem/sds-komponentbibliotek/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.sikt.no/designsystem/sds-komponentbibliotek.git"
  },
  "workspaces": [
    "packages/*",
    "storybook"
  ],
  "scripts": {
    "prebuild": "npm run clean && npm run prebuild --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "clean": "rimraf packages/**/dist && rimraf storybook/storybook-static",
    "format": "prettier --write . --ignore-unknown",
    "lint": "run-p lint:*",
    "lint:css": "stylelint \"**/*.{css,pcss}\" --ignore-path .gitignore",
    "lint:ts": "eslint \"**/*.{ts,tsx}\" --ignore-path .gitignore",
    "prepare": "husky install",
    "prerelease": "cross-var npm run build --workspace=packages/$npm_config_package --if-present",
    "release": "standard-version",
    "storybook": "npm run storybook --workspace=storybook",
    "storybook:build": "npm run build-storybook --workspace=storybook",
    "test": "jest"
  },
  "browserslist": [
    ">0.2% in NO",
    "not dead",
    "not ie <= 11"
  ],
  "lint-staged": {
    "**/*.{css,pcss}": "stylelint --fix",
    "**/*.{ts,tsx}": "eslint --fix",
    "**/*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.4.2",
    "@commitlint/config-conventional": "^17.4.2",
    "@rollup/plugin-terser": "^0.4.0",
    "@rollup/plugin-url": "^8.0.1",
    "@svgr/rollup": "^6.5.1",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/jest": "^29.4.0",
    "@types/jest-axe": "^3.5.5",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.10",
    "@typescript-eslint/eslint-plugin": "^5.51.0",
    "@typescript-eslint/parser": "^5.51.0",
    "autoprefixer": "^10.4.13",
    "clsx": "^1.2.1",
    "cross-var": "^1.1.0",
    "eslint": "^8.34.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "husky": "^8.0.3",
    "jest": "^29.4.2",
    "jest-axe": "^7.0.0",
    "jest-environment-jsdom": "^29.4.2",
    "jest-esm-transformer": "^1.0.0",
    "lint-staged": "^13.1.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.20",
    "postcss-custom-media": "^9.1.2",
    "postcss-import": "^15.1.0",
    "postcss-nested": "^6.0.0",
    "prettier": "2.8.4",
    "rimraf": "^4.0.0",
    "rollup": "^3.15.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-ts": "^3.2.0",
    "standard-version": "^9.5.0",
    "stylelint": "^15.0.0",
    "ts-jest": "^29.0.5",
    "typescript": "^4.9.5"
  }
}
