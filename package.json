{
  "name": "@sikt/sds-komponentbibliotek",
  "version": "1.0.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "description": "Sikt component library",
  "homepage": "https://designsystem.sikt.no/",
  "bugs": {
    "url": "https://sikt.atlassian.net/jira/software/c/projects/SDS/boards/1331"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.sikt.no/designsystem/sds-komponentbibliotek.git"
  },
  "engines": {
    "node": "24.18.0"
  },
  "packageManager": "npm@11.18.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prebuild": "npm run clean:build && npm run prebuild --workspaces --if-present",
    "build": "turbo run build --filter=./packages/*",
    "build:astro": "npm run build --workspace=apps/astro",
    "build:storybook": "npm run build --workspace=apps/storybook",
    "clean": "run-p clean:*",
    "clean:build": "rimraf --glob packages/*/{build,dist}",
    "clean:astro": "rimraf apps/astro/dist",
    "clean:storybook": "rimraf apps/storybook/storybook-static && rimraf apps/storybook/node_modules/.cache",
    "dev": "run-p dev:astro dev:storybook",
    "dev:astro": "npm run dev --workspace=apps/astro",
    "dev:storybook": "npm run dev --workspace=apps/storybook",
    "deps:fix": "syncpack fix --dependencies '$LOCAL' --specifier-types range",
    "format": "prettier . --write --ignore-unknown",
    "init": "turbo gen init-package",
    "postinstall": "npm run prebuild --workspaces --if-present",
    "lint": "run-p lint:*",
    "lint:css": "stylelint \"**/*.{css,pcss}\" --ignore-path .gitignore",
    "lint:ts": "eslint \"**/*.{ts,tsx}\"",
    "prepare": "husky",
    "release": "commit-and-tag-version",
    "skill:sync": "node --experimental-strip-types --no-warnings=ExperimentalWarning .claude/plugins/skills/sikt-design-system/scripts/aggregate.ts && prettier .claude/plugins/skills/sikt-design-system/references --write --ignore-unknown",
    "test": "npm run test:unit",
    "test:unit": "jest",
    "test:e2e": "playwright test"
  },
  "browserslist": [
    "extends @sikt/browserslist-config-sds"
  ],
  "lint-staged": {
    "**/*.{css,pcss}": "stylelint --fix",
    "**/*.{ts,tsx}": "eslint --fix",
    "**/*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@figma/code-connect": "^1.4.9",
    "@playwright/test": "^1.61.1",
    "@svgr/rollup": "^8.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tsdown/css": "^0.22.3",
    "@turbo/gen": "^2.10.3",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "browserslist": "^4.28.5",
    "browserslist-to-esbuild": "^2.1.1",
    "clsx": "^2.1.1",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "jest-junit": "^17.0.0",
    "lint-staged": "^17.0.8",
    "npm-run-all2": "^9.0.2",
    "postcss": "^8.5.16",
    "postcss-custom-media": "^12.0.1",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "postcss-selector-parser": "^7.1.4",
    "prettier": "^3.9.4",
    "publint": "^0.3.21",
    "rimraf": "^6.1.3",
    "stylelint": "^17.14.0",
    "syncpack": "^15.3.2",
    "ts-jest": "^29.4.11",
    "tsdown": "^0.22.3",
    "turbo": "^2.10.3",
    "typescript": "^6.0.3"
  }
}
