{
  "name": "@sikt/sds-komponentbibliotek",
  "version": "1.0.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "description": "Sikt component library",
  "homepage": "https://designsystem.sikt.no/komponenter/",
  "bugs": {
    "url": "https://gitlab.sikt.no/designsystem/sds-komponentbibliotek/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.sikt.no/designsystem/sds-komponentbibliotek.git"
  },
  "workspaces": [
    "packages/*",
    "gatsby",
    "storybook"
  ],
  "scripts": {
    "prebuild": "npm run clean && npm run prebuild --workspaces --if-present",
    "build": "turbo run build",
    "clean": "run-p clean:*",
    "clean:build": "rimraf packages/**/{build,dist}",
    "clean:gatsby": "rimraf gatsby/public",
    "clean:storybook": "rimraf storybook/storybook-static",
    "format": "prettier --write . --ignore-unknown",
    "init": "bin/init-package.sh $npm_config_package",
    "lint": "run-p lint:*",
    "lint:css": "stylelint \"**/*.{css,pcss}\" --ignore-path .gitignore",
    "lint:ts": "eslint \"**/*.{ts,tsx}\" --ignore-path .gitignore",
    "prepare": "husky install",
    "prerelease": "cross-var npm run build --workspace=packages/$npm_config_package --if-present",
    "release": "standard-version",
    "storybook": "npm run dev --workspace=storybook",
    "storybook:build": "npm run build:prod --workspace=storybook",
    "gatsby": "npm run develop --workspace=gatsby",
    "gatsby:build": "npm run build:prod --workspace=gatsby",
    "test": "npm run test:unit",
    "test:unit": "jest",
    "test:e2e": "playwright test"
  },
  "browserslist": [
    ">0.2% in NO",
    "not dead",
    "not ie <= 11"
  ],
  "lint-staged": {
    "**/*.{css,pcss}": "stylelint --fix",
    "**/*.{ts,tsx}": "eslint --fix",
    "**/*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.8.2",
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@playwright/test": "^1.40.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.11",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "autoprefixer": "^10.4.16",
    "browserslist-to-esbuild": "^1.2.0",
    "clsx": "^2.0.0",
    "cross-var": "^1.1.0",
    "esbuild-plugin-svgr": "^2.1.0",
    "esbuild-postcss": "^0.0.4",
    "eslint": "^8.56.0",
    "eslint-plugin-jest": "^27.6.0",
    "eslint-plugin-testing-library": "^6.2.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-axe": "^8.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-esm-transformer": "^1.0.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^15.2.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.32",
    "postcss-custom-media": "^10.0.2",
    "postcss-import": "^15.1.0",
    "postcss-nested": "^6.0.1",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "standard-version": "^9.5.0",
    "stylelint": "^16.0.2",
    "terser": "^5.26.0",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.1",
    "turbo": "^1.11.2",
    "typescript": "^5.3.3"
  }
}
