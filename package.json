{
  "name": "@sikt/sds-komponentbibliotek",
  "version": "1.0.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "description": "Sikt component library",
  "homepage": "https://designsystem.sikt.no/",
  "bugs": {
    "url": "https://gitlab.sikt.no/designsystem/sds-komponentbibliotek/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.sikt.no/designsystem/sds-komponentbibliotek.git"
  },
  "engines": {
    "node": "22.19.0"
  },
  "packageManager": "npm@11.5.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prebuild": "npm run clean:build && npm run prebuild --workspaces --if-present",
    "build": "turbo run build --filter=./packages/*",
    "build:astro": "npm run build --workspace=apps/astro",
    "build:storybook": "npm run build --workspace=apps/storybook",
    "clean": "run-p clean:*",
    "clean:build": "rimraf --glob packages/*/{build,dist}",
    "clean:astro": "rimraf apps/astro/dist",
    "clean:storybook": "rimraf apps/storybook/storybook-static && rimraf apps/storybook/node_modules/.cache",
    "dev": "run-p dev:astro dev:storybook",
    "dev:astro": "npm run dev --workspace=apps/astro",
    "dev:storybook": "npm run dev --workspace=apps/storybook",
    "format": "prettier . --write --ignore-unknown",
    "init": "turbo gen init-package",
    "postinstall": "npm run prebuild --workspaces --if-present",
    "lint": "run-p lint:*",
    "lint:css": "stylelint \"**/*.{css,pcss}\" --ignore-path .gitignore",
    "lint:ts": "eslint \"**/*.{ts,tsx}\"",
    "prepare": "husky",
    "release": "commit-and-tag-version",
    "test": "npm run test:unit",
    "test:unit": "jest",
    "test:e2e": "playwright test"
  },
  "browserslist": [
    "extends @sikt/browserslist-config-sds"
  ],
  "lint-staged": {
    "**/*.{css,pcss}": "stylelint --fix",
    "**/*.{ts,tsx}": "eslint --fix",
    "**/*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/compat": "^1.3.2",
    "@figma/code-connect": "^1.3.5",
    "@playwright/test": "^1.55.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@turbo/gen": "^2.5.6",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.18.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.4.21",
    "browserslist": "^4.25.4",
    "browserslist-to-esbuild": "^2.1.1",
    "clsx": "^2.1.1",
    "commit-and-tag-version": "^12.6.0",
    "esbuild-plugin-svgr": "^3.1.1",
    "esbuild-postcss": "^0.0.4",
    "eslint": "^9.34.0",
    "husky": "^9.1.7",
    "jest": "^30.1.3",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.1.2",
    "jest-esm-transformer": "^1.0.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.1.6",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.6",
    "postcss-custom-media": "^11.0.6",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "stylelint": "^16.23.1",
    "terser": "^5.44.0",
    "ts-jest": "^29.4.1",
    "tsup": "^8.5.0",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  }
}
