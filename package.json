{
  "name": "@sikt/sds-komponentbibliotek",
  "version": "1.0.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "description": "Sikt component library",
  "homepage": "https://designsystem.sikt.no/",
  "bugs": {
    "url": "https://gitlab.sikt.no/designsystem/sds-komponentbibliotek/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.sikt.no/designsystem/sds-komponentbibliotek.git"
  },
  "engines": {
    "node": "20.15.0"
  },
  "packageManager": "npm@10.8.1",
  "workspaces": [
    "packages/*",
    "gatsby",
    "storybook"
  ],
  "scripts": {
    "build": "turbo run build",
    "prebuild": "npm run clean && npm run prebuild --workspaces --if-present",
    "clean": "run-p clean:*",
    "clean:build": "rimraf --glob packages/**/{build,dist}",
    "clean:gatsby": "npm run clean --workspace=gatsby",
    "clean:storybook": "rimraf storybook/storybook-static && rimraf storybook/node_modules/.cache",
    "format": "prettier --write . --ignore-unknown",
    "gatsby": "npm run develop --workspace=gatsby",
    "gatsby:build": "npm run build:prod --workspace=gatsby",
    "init": "bin/init-package.sh $npm_config_package",
    "postinstall": "npm run prebuild --workspaces --if-present",
    "lint": "run-p lint:*",
    "lint:css": "stylelint \"**/*.{css,pcss}\" --ignore-path .gitignore",
    "lint:ts": "eslint \"**/*.{ts,tsx}\" --ignore-path .gitignore",
    "prepare": "husky",
    "release": "commit-and-tag-version",
    "prerelease": "cross-replace npm run build --workspace=packages/$npm_config_package --if-present",
    "storybook": "npm run dev --workspace=storybook",
    "storybook:build": "npm run build:prod --workspace=storybook",
    "test": "npm run test:unit",
    "test:unit": "jest",
    "test:e2e": "playwright test"
  },
  "browserslist": [
    "extends @sikt/browserslist-config-sds"
  ],
  "lint-staged": {
    "**/*.{css,pcss}": "stylelint --fix",
    "**/*.{ts,tsx}": "eslint --fix",
    "**/*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.9.1",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@playwright/test": "^1.45.1",
    "@testing-library/dom": "^10.3.1",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "browserslist": "^4.23.1",
    "browserslist-to-esbuild": "^2.1.1",
    "clsx": "^2.1.1",
    "commit-and-tag-version": "^12.4.1",
    "cross-replace": "^0.2.0",
    "esbuild-plugin-svgr": "^2.1.0",
    "esbuild-postcss": "^0.0.4",
    "eslint": "^8.57.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-axe": "^9.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-esm-transformer": "^1.0.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^15.2.7",
    "npm-run-all2": "^6.2.2",
    "postcss": "^8.4.39",
    "postcss-custom-media": "^10.0.8",
    "postcss-import": "^16.1.0",
    "postcss-nested": "^6.0.1",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.8",
    "stylelint": "^16.6.1",
    "terser": "^5.31.1",
    "ts-jest": "^29.1.5",
    "tsup": "^8.1.0",
    "turbo": "^2.0.6",
    "typescript": "^5.5.3",
    "usehooks-ts": "^3.1.0"
  }
}
