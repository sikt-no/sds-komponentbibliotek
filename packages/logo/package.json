{
  "name": "@sikt/sds-logo",
  "version": "2.0.0",
  "license": "UNLICENSED",
  "type": "commonjs",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "style": "./dist/index.css"
    },
    "./dist/*": "./dist/*",
    "./*.png": "./*.png",
    "./*.svg": "./*.svg"
  },
  "types": "dist/index.d.ts",
  "style": "dist/index.css",
  "files": [
    "CHANGELOG.md",
    "dist",
    "README.md",
    "*.png",
    "*.svg"
  ],
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@sikt/sds-core": "^3.0.2"
  },
  "peerDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "clsx": "^2.1.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
