.sds-logo {
  align-items: center;
  display: flex;
  flex-direction: row;
  gap: var(--sds-size-base-s);

  &__icon {
    width: 1.8em;
  }

  &--primary {
    font-size: var(--sds-size-text-m2);
    font-weight: 400;
    line-height: 1em;
  }

  &--secondary {
    font-size: var(--sds-size-text-s1);
    font-weight: 600;
    line-height: 1em;

    .sds-logo__subtitle {
      font-weight: 400;
    }

    .sds-logo__icon {
      width: 4.7em;
    }
  }
}
