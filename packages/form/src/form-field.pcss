@import url("./label.pcss");
@import url("./help-text.pcss");

.sds-form {
  &-field {
    position: relative;

    &__help-text-wrapper {
      padding-bottom: var(--sds-space-padding-minimal);
    }

    &__after {
      display: flex;
      gap: var(--sds-space-gap-tiny);
      padding: calc(var(--input-padding) + var(--input-border-width));
      position: absolute;
      bottom: 0;
      right: 0;
    }
  }
}
