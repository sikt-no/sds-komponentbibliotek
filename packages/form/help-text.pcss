.sds-form-field__help-text {
  --help-text-color: var(--sds-color-text-neutral);

  font-size: var(--sds-size-text-s);
  line-height: var(--sds-size-text-s1);
  color: var(--help-text-color);
  padding: var(--sds-size-padding-small);

  &--error {
    --help-text-color: var(--sds-color-text-danger);
  }
}
