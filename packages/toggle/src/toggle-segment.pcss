.sds-toggle-segment {
  --toggle-segment-border: var(--sds-space-border-weight-regular) solid
    var(--sds-color-interaction-primary-strong-default);

  &--horizontal &__fieldset {
    display: flex;
    align-items: center;

    .sds-form-fieldset__legend {
      float: left;
    }
  }

  &__group {
    border-radius: var(--sds-space-border-radius-small);
    display: inline-grid;
    grid-auto-flow: column;
    outline: var(--toggle-segment-border);
    outline-offset: calc(var(--sds-space-border-weight-regular) * -1);
  }

  &--fixed &__group {
    grid-auto-columns: 1fr;
  }

  &__option {
    align-items: center;
    display: flex;
    justify-content: center;

    &:first-child {
      border-radius: var(--sds-space-border-radius-small) 0 0
        var(--sds-space-border-radius-small);
    }

    &:last-child {
      border-radius: 0 var(--sds-space-border-radius-small)
        var(--sds-space-border-radius-small) 0;
    }

    + .sds-toggle-segment__option {
      border-left: var(--toggle-segment-border);
    }

    &:hover {
      background: var(--sds-color-interaction-primary-transparent-highlight);
    }

    &:active {
      background: var(--sds-color-interaction-primary-transparent-pressed);
    }

    &--checked {
      background-color: var(--sds-color-interaction-primary-strong-default);
      color: var(--sds-color-text-on-strong);

      &:hover {
        background-color: var(--sds-color-interaction-primary-strong-highlight);
      }

      &:active {
        background-color: var(--sds-color-interaction-primary-strong-pressed);
      }
    }

    &:has(:focus-visible) {
      outline: var(--sds-focus-outline);
    }
  }

  &__label {
    border-radius: var(--sds-space-border-radius-small);
    cursor: pointer;
    font-size: var(--sds-typography-label-default-fontsize);
    font-weight: var(--sds-typography-label-default-fontweight);
    line-height: var(--sds-typography-label-default-lineheight);
    min-width: 44px;
    padding: var(--sds-space-padding-small);
    position: relative;
    text-align: center;
    width: 100%;
  }

  &__input {
    opacity: 0;
    position: absolute;
    pointer-events: none;
  }
}
