.sds-filter-list {
  display: flex;
  flex-direction: column;
  padding: var(--sds-space-padding-small);

  .sds-form-fieldset__legend {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    white-space: nowrap;
    border-width: 0;
  }
}
