.sds-filter-list {
  background: var(--sds-color-layout-background-default);
  display: flex;
  flex-direction: column;
  padding: var(--sds-space-padding-small);

  &__badge {
    justify-content: center;
    min-width: var(--sds-base-size-m1);
  }

  .sds-form-fieldset__legend {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
}
