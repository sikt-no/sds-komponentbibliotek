.sds-filter-list-category {
  &__header {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: var(--sds-space-gap-tiny);
    width: 100%;

    &-label {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;
      gap: var(--sds-space-gap-tiny);
    }
  }

  &__content {
    padding-left: var(--sds-space-padding-small);
  }
}
