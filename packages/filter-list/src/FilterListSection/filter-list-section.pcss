.sds-filter-list-section {
  &__header {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: var(--sds-space-gap-tiny);
    width: 100%;
    padding: var(--sds-space-padding-small);

    &--expandable {
      padding-right: 0;
    }
  }
}
