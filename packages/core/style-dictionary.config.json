{
  "source": ["tokens/**/*.json"],
  "platforms": {
    "css": {
      "transformGroup": "css",
      "buildPath": "dist/tokens/",
      "prefix": "horisont",
      "files": [
        {
          "format": "css/variables",
          "destination": "css/tokens.css"
        }
      ]
    },
    "ts": {
      "transformGroup": "js",
      "buildPath": "dist/tokens/",
      "prefix": "horisont",
      "files": [
        {
          "format": "javascript/module",
          "destination": "ts/tokens.js"
        },
        {
          "format": "typescript/module-declarations",
          "destination": "ts/tokens.d.ts"
        }
      ]
    }
  }
}
