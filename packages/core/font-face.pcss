@font-face {
  font-family: "Haffer";
  font-display: swap;
  font-style: normal;
  font-weight: 400;
  src: url("./fonts/Haffer-Regular.woff2") format("woff2"),
    url("./fonts/Haffer-Regular.woff") format("woff");
}

@font-face {
  font-family: "Haffer";
  font-display: swap;
  font-style: normal;
  font-weight: 700;
  src: url("./fonts/Haffer-SemiBold.woff2") format("woff2"),
    url("./fonts/Haffer-SemiBold.woff") format("woff");
}
