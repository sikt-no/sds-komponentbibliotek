/*
  INFO: Deprecated

  Classes:
  - `.sds-typography-heading-*` replaced by `.sds-typography-*-headline-*`

  Custom properties
  - `--sds-base-size-relative-*` replaced by `--sds-typography-fontsize-*`
  - `--sds-typography-weight-*` replaced by `--sds-typography-fontweight-*`
  - `--sds-typography-heading-*` replaced by `--sds-typography-*-headline-*`
*/
:root {
  --sds-base-size-relative-xxs: calc(4rem / 16);
  --sds-base-size-relative-xs: calc(8rem / 16);
  --sds-base-size-relative-s: calc(12rem / 16);
  --sds-base-size-relative-s1: calc(16rem / 16);
  --sds-base-size-relative-m: calc(24rem / 16);
  --sds-base-size-relative-m1: calc(32rem / 16);
  --sds-base-size-relative-l: calc(48rem / 16);
  --sds-base-size-relative-xl: calc(96rem / 16);
  --sds-base-size-relative-xxl: calc(192rem / 16);
  --sds-typography-weight-regular: 400;
  --sds-typography-weight-bold: 600;
  --sds-typography-heading-fontsize-overline: calc(12.8rem / 16);
  --sds-typography-heading-lineheight-overline: calc(calc(12.8rem / 16) * 1.25);
  --sds-typography-heading-fontsize-paragraph: calc(19.2rem / 16);
  --sds-typography-heading-lineheight-paragraph: calc(
    calc(19.2rem / 16) * 1.25
  );
  --sds-typography-heading-fontsize-small: calc(25.6rem / 16);
  --sds-typography-heading-lineheight-small: calc(calc(25.6rem / 16) * 1.25);
  --sds-typography-heading-fontsize-medium: calc(32rem / 16);
  --sds-typography-heading-lineheight-medium: calc(calc(32rem / 16) * 1.25);
  --sds-typography-heading-fontsize-large: calc(38.4rem / 16);
  --sds-typography-heading-lineheight-large: calc(calc(38.4rem / 16) * 1.25);
  --sds-typography-heading-fontsize-xlarge: calc(44.8rem / 16);
  --sds-typography-heading-lineheight-xlarge: calc(calc(44.8rem / 16) * 1.25);
  --sds-typography-heading-fontsize-huge: calc(51.2rem / 16);
  --sds-typography-heading-lineheight-huge: calc(calc(51.2rem / 16) * 1.25);

  @media (--sds-base-breakpoint-tablet) {
    --sds-typography-heading-fontsize-large: calc(44.8rem / 16);
    --sds-typography-heading-lineheight-large: calc(calc(44.8rem / 16) * 1.25);
    --sds-typography-heading-fontsize-xlarge: calc(51.2rem / 16);
    --sds-typography-heading-lineheight-xlarge: calc(calc(51.2rem / 16) * 1.25);
    --sds-typography-heading-fontsize-huge: calc(64rem / 16);
    --sds-typography-heading-lineheight-huge: calc(calc(64rem / 16) * 1.25);
  }

  @media (--sds-base-breakpoint-desktop) {
    --sds-typography-heading-fontsize-large: calc(51.2rem / 16);
    --sds-typography-heading-lineheight-large: calc(calc(51.2rem / 16) * 1.25);
    --sds-typography-heading-fontsize-xlarge: calc(64rem / 16);
    --sds-typography-heading-lineheight-xlarge: calc(calc(64rem / 16) * 1.25);
    --sds-typography-heading-fontsize-huge: calc(76.8rem / 16);
    --sds-typography-heading-lineheight-huge: calc(calc(76.8rem / 16) * 1.25);
  }
}

.sds-typography {
  &-heading {
    &--huge {
      font-size: var(--sds-typography-heading-fontsize-huge);
      font-weight: var(--sds-typography-weight-bold);
      line-height: var(--sds-typography-heading-lineheight-huge);
    }

    &--xlarge {
      font-size: var(--sds-typography-heading-fontsize-xlarge);
      font-weight: var(--sds-typography-weight-bold);
      line-height: var(--sds-typography-heading-lineheight-xlarge);
    }

    &--large {
      font-size: var(--sds-typography-heading-fontsize-large);
      font-weight: var(--sds-typography-weight-bold);
      line-height: var(--sds-typography-heading-lineheight-large);
    }

    &--medium {
      font-size: var(--sds-typography-heading-fontsize-medium);
      font-weight: var(--sds-typography-weight-regular);
      line-height: var(--sds-typography-heading-lineheight-medium);
    }

    &--small {
      font-size: var(--sds-typography-heading-fontsize-small);
      font-weight: var(--sds-typography-weight-regular);
      line-height: var(--sds-typography-heading-lineheight-small);
    }

    &--paragraph {
      font-size: var(--sds-typography-heading-fontsize-paragraph);
      font-weight: var(--sds-typography-weight-bold);
      line-height: var(--sds-typography-heading-lineheight-paragraph);
    }

    &--overline {
      font-size: var(--sds-typography-heading-fontsize-overline);
      font-weight: var(--sds-typography-weight-bold);
      line-height: var(--sds-typography-heading-lineheight-overline);
      text-transform: uppercase;
    }
  }
}
