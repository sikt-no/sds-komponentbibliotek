.sds-badge {
  --badge-background-color: var(--sds-color-background-action);
  --badge-border-color: var(--sds-color-surface-action);

  background-color: var(--badge-background-color);
  color: var(--sds-color-text-default);
  border: 1px solid var(--badge-border-color);
  border-radius: var(--sds-size-base-m);
  padding: var(--sds-size-base-xxs) var(--sds-size-base-xs);
  font-size: var(--sds-size-text-s);
  line-height: var(--sds-size-text-s1);
  display: inline-flex;
  align-items: center;

  &--success {
    --badge-background-color: var(--sds-color-background-success);
    --badge-border-color: var(--sds-color-surface-success);
  }

  &--danger {
    --badge-background-color: var(--sds-color-background-danger);
    --badge-border-color: var(--sds-color-surface-danger);
  }

  &--warning {
    --badge-background-color: var(--sds-color-background-warning);
    --badge-border-color: var(--sds-color-surface-warning);
  }

  &--info {
    --badge-background-color: var(--sds-color-background-info);
    --badge-border-color: var(--sds-color-surface-info);
  }

  &__icon {
    align-items: center;
    display: inline-flex;
    font-size: var(--sds-size-text-s1);
    justify-content: center;
    width: var(--sds-size-text-s1);
    height: var(--sds-size-text-s1);
    margin-right: var(--sds-size-base-xxs1);
  }
}
