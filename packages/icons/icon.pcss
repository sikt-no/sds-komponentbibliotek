.sds-icon {
  fill: currentcolor;
  stroke: currentcolor;
  stroke-width: 1;
  stroke-linecap: round;
  stroke-linejoin: round;
  width: 1em;
  height: 1em;

  &__custom--black {
    fill: #000;
    stroke: #000;
  }

  &__custom--white {
    fill: #fff;
    stroke: #fff;
  }

  &--spinner {
    animation: spinner 1s steps(8, end) infinite;

    @keyframes spinner {
      to {
        transform: rotate(360deg);
      }
    }
  }
}
