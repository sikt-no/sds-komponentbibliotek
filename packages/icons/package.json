{
  "name": "@sikt/sds-icons",
  "version": "1.2.0",
  "license": "SEE LICENSE IN LICENSE.md",
  "main": "dist/cjs/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "style": "dist/index.css",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "npm run prepare",
    "build": "rollup -c ../../rollup.config.mjs",
    "build:icons": "node bin/build.mjs",
    "build:components": "svgr -- dist/assets",
    "build:sprite": "svgstore dist/assets/*.svg -o dist/sds-icons.svg",
    "prepare": "run-s build:icons build:sprite build:components"
  },
  "dependencies": {
    "@phosphor-icons/core": "^2.0.2"
  },
  "devDependencies": {
    "@svgr/cli": "^8.1.0",
    "cpy": "^10.1.0",
    "svgstore-cli": "^2.0.1"
  },
  "peerDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "clsx": "^1.2.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
