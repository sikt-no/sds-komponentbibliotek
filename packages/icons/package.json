{
  "name": "@sikt/sds-icons",
  "version": "2.0.1",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "commonjs",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "style": "./dist/index.css"
    },
    "./dist/*": "./dist/*",
    "./*.svg": "./dist/*.svg",
    "./assets/*.svg": "./dist/assets/*.svg"
  },
  "types": "dist/index.d.ts",
  "style": "dist/index.css",
  "files": [
    "CHANGELOG.md",
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "run-s build:*",
    "build": "tsup",
    "build:icons": "node bin/build.mjs",
    "build:components": "svgr -- dist/assets",
    "build:sprite": "svgstore dist/assets/*.svg -o dist/sds-icons.svg"
  },
  "dependencies": {
    "@phosphor-icons/core": "^2.1.1"
  },
  "devDependencies": {
    "@svgr/cli": "^8.1.0",
    "cpy": "^11.1.0",
    "run-p": "^0.0.0",
    "svgstore-cli": "^2.0.1"
  },
  "peerDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "clsx": "^1.0.0 || ^2.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
