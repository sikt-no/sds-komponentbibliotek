@import url("@sikt/sds-tokens/dist/css/custom-media.css");

.sds-section {
  display: flex;
  flex-direction: column;

  &__header {
    border-bottom: var(--sds-space-border-weight-thin) solid
      var(--sds-color-layout-divider-subtle);
    display: flex;
    flex-direction: column;
    padding-bottom: var(--sds-space-gap-medium);
  }

  &__heading {
    padding-bottom: var(--sds-space-gap-medium);
  }

  &__link {
    display: flex;
    justify-content: flex-end;
  }

  &__content {
    padding-top: var(--sds-space-gap-medium);
  }

  @media (--sds-base-breakpoint-tablet) {
    &__header {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }

    &__heading {
      padding-bottom: 0;
    }
  }
}
