{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":disableDependencyDashboard",
    ":rebaseStalePrs",
    ":disablePeerDependencies"
  ],
  "addLabels": ["dependencies"],
  "automerge": true,
  "gitLabIgnoreApprovals": true,
  "platformAutomerge": true,
  "major": {
    "automerge": false,
    "gitLabIgnoreApprovals": false,
    "platformAutomerge": false
  },
  "updateLockFiles": true,
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "matchPackagePatterns": ["react"],
      "groupName": "react"
    },
    {
      "matchPackagePatterns": ["tsup", "esbuild"],
      "groupName": "esbuild"
    },
    {
      "matchPackagePatterns": ["typescript"],
      "groupName": "typescript"
    },
    {
      "matchPackagePatterns": ["^postcss"],
      "groupName": "postcss"
    },
    {
      "matchPackagePatterns": ["^@commitlint"],
      "groupName": "commitlint"
    },
    {
      "matchPackagePatterns": ["eslint"],
      "groupName": "eslint"
    },
    {
      "matchPackagePatterns": ["stylelint"],
      "groupName": "stylelint"
    },
    {
      "matchPackagePatterns": ["jest", "^@testing-library"],
      "groupName": "jest"
    },
    {
      "matchPackagePatterns": ["^@storybook", "storybook"],
      "groupName": "storybook"
    },
    {
      "matchPackagePatterns": ["^@babel"],
      "groupName": "babel"
    },
    {
      "matchPackagePatterns": ["^gatsby"],
      "groupName": "gatsby"
    },
    {
      "matchPackagePatterns": ["^@sikt"],
      "groupName": "sikt"
    }
  ]
}
