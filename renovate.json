{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":disableDependencyDashboard",
    ":rebaseStalePrs",
    ":disablePeerDependencies"
  ],
  "addLabels": ["dependencies"],
  "automerge": true,
  "gitLabIgnoreApprovals": true,
  "platformAutomerge": true,
  "major": {
    "automerge": false,
    "gitLabIgnoreApprovals": false,
    "platformAutomerge": false
  },
  "updateLockFiles": true,
  "rangeStrategy": "bump",
  "minimumReleaseAge": "5 days",
  "ignorePaths": ["**/node_modules/**", "**/__example__/**", "turbo/**"],
  "packageRules": [
    {
      "matchPackagePatterns": ["react"],
      "excludeDepPatterns": [
        "^@phosphor-icons",
        "react-aria-components",
        "react-syntax-highlighter",
        "@mdx-js/react"
      ],
      "groupName": "react"
    },
    {
      "matchPackagePatterns": ["^node$", "^@types/node$"],
      "groupName": "node"
    },
    {
      "matchPackagePatterns": [
        "tsup",
        "esbuild",
        "terser",
        "browserslist-to-esbuild"
      ],
      "groupName": "esbuild"
    },
    {
      "matchPackagePatterns": ["typescript"],
      "groupName": "typescript"
    },
    {
      "matchPackagePatterns": ["^turbo", "^@turbo"],
      "groupName": "turbo"
    },
    {
      "matchPackagePatterns": ["^postcss"],
      "groupName": "postcss"
    },
    {
      "matchPackagePatterns": ["^@commitlint"],
      "groupName": "commitlint"
    },
    {
      "matchPackagePatterns": ["eslint", "eslint-plugin-jest", "globals"],
      "groupName": "eslint"
    },
    {
      "matchPackagePatterns": ["stylelint"],
      "groupName": "stylelint"
    },
    {
      "matchPackagePatterns": ["jest", "^@testing-library"],
      "groupName": "jest"
    },
    {
      "matchPackagePatterns": ["playwright"],
      "groupName": "playwright",
      "matchUpdateTypes": ["major", "minor"],
      "automerge": false,
      "gitLabIgnoreApprovals": false,
      "platformAutomerge": false
    },
    {
      "matchPackagePatterns": ["playwright"],
      "groupName": "playwright",
      "matchUpdateTypes": ["patch"]
    },
    {
      "matchPackagePatterns": [
        "^@storybook",
        "storybook",
        "react-syntax-highlighter"
      ],
      "groupName": "storybook"
    },
    {
      "matchPackagePatterns": ["^@sikt"],
      "groupName": "sikt"
    },
    {
      "matchPackagePatterns": ["^platon"],
      "groupName": "platon"
    },
    {
      "matchPackagePatterns": ["^@astrojs", "^astro"],
      "groupName": "astro"
    }
  ]
}
