---
import Layout from "./Layout.astro";
import { Menu } from "../components";

const { pathname } = Astro.url;
const { title } = Astro.props;
---

<Layout title={title}>
  <div class="page">
    <div class="menu">
      <Menu pathname={pathname} />
    </div>
    <div class="content">
      <div class="container">
        <div class="wrapper">
          {/* TODO: Hero */}
          <slot name="hero" />
          <slot />
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  @import url("@sikt/sds-tokens/dist/css/custom-media.css");

  @custom-media --breakpoint-ultrawide (width >= 1800px);

  .page {
    display: grid;

    @media (--sds-base-breakpoint-tablet) {
      grid-template-columns: 338px auto;
    }
  }

  .menu {
    display: flex;
    flex-direction: column;
    gap: var(--sds-space-gap-medium);
    padding: var(--sds-space-padding-large);
  }

  .content {
    background-color: var(--sds-color-layout-page-default);
    padding: var(--sds-space-padding-huge);
  }

  .container {
    container: page / inline-size;
    display: flex;

    @media (--breakpoint-ultrawide) {
      justify-content: center;
    }
  }

  .wrapper {
    display: grid;
    gap: var(--sds-space-padding-huge);
    max-width: 920px;

    @media (--breakpoint-ultrawide) {
      margin-left: -10vw;
    }
  }
</style>
