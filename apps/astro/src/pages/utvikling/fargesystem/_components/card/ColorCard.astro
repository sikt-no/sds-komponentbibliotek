---
import { DarkToken, Token } from "../../../../../components";
import Swatch from "./Swatch.astro";
import { Badge } from "@sikt/sds-badge";
import { tokenName } from "../../../../../utils/token";

const { token } = Astro.props;
---

<div class="card">
  <div class="name">
    <Badge visibility="strong">{tokenName(token[1])}</Badge>
  </div>
  <div class="content">
    <div class="item" data-color-scheme="light">
      <Swatch color={token[1].$value} />
      <div>
        <Token token={token[1]} />
      </div>
    </div>
    <div class="item" data-color-scheme="dark">
      <Swatch color={token[1].dark} />
      <div>
        <DarkToken token={token[1]} />
      </div>
    </div>
  </div>
</div>

<style>
  .card {
    align-items: center;
    display: grid;
    gap: var(--sds-space-padding-medium);
    grid-template-columns: 3fr 4fr;
    justify-content: space-between;

    &:first-child {
      .item {
        border-top-right-radius: var(--color-card-border-radius);
      }
    }

    &:last-child {
      .item {
        border-bottom-right-radius: var(--color-card-border-radius);
      }
    }
  }

  .name {
    padding-left: var(--sds-space-padding-small);
  }

  .content {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .item {
    align-items: center;
    background-color: var(--sds-color-layout-background-default);
    color: var(--sds-color-text-primary);
    display: flex;
    gap: var(--sds-space-padding-small);
    padding: var(--sds-space-padding-small);
  }
</style>
