---
import Layout from "../../layouts/PageLayout.astro";
import { Contributors } from "./_components/contributors/Contributors";
import { Hero } from "../../components";

const pageTitle = "Laget med kjærlighet";
const isJune = new Date().getMonth() === 5;
const titleSuffix = isJune ? "🧡💛💚💙💜" : "";
---

<Layout title={pageTitle}>
  <Hero
    breadcrumbs={[{ title: "Designsystem", href: "/" }]}
    heading=`Laget med kjærlighet ❤️${titleSuffix}`
    slot="hero"
  />

  <Contributors client:load />
</Layout>
