{
  "name": "@sikt/sds-storybook",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run copy:css && storybook dev -p 6006",
    "build": "npm run copy:css && storybook build --disable-telemetry",
    "copy:css": "run-p copy:css:*",
    "copy:css:core": "cpy ../../packages/core/dist/*.css static/dist/ --flat --rename=core.css",
    "copy:css:header": "cpy ../../packages/header/dist/*.css static/dist/ --flat --rename=header.css",
    "copy:css:logo": "cpy ../../packages/logo/dist/*.css static/dist/ --flat --rename=logo.css"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/react-vite": "^10.4.6",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@whitespace/storybook-addon-html": "^9.0.0",
    "cpy-cli": "^7.0.0",
    "storybook": "^10.4.6",
    "vite": "^8.1.2",
    "vite-plugin-svgr": "^5.2.0"
  }
}
